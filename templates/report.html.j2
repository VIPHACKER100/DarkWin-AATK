<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DARKWIN Report — {{ target }}</title>
  <style>
    :root {
      --bg: #0d0d0d;
      --surface: #161616;
      --surface2: #1e1e1e;
      --border: #2a2a2a;
      --accent: #00ff88;
      --accent2: #00bfff;
      --red: #ff4d4d;
      --yellow: #ffd700;
      --text: #e0e0e0;
      --dim: #888;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Courier New', monospace;
      line-height: 1.6;
    }
    header {
      background: linear-gradient(135deg, #0a0a0a 0%, #111 100%);
      border-bottom: 1px solid var(--accent);
      padding: 2rem 3rem;
    }
    header h1 {
      font-size: 2rem;
      color: var(--accent);
      letter-spacing: 4px;
      text-transform: uppercase;
    }
    header .meta {
      margin-top: 1rem;
      display: flex;
      gap: 2rem;
      flex-wrap: wrap;
    }
    header .meta-item {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 0.5rem 1rem;
    }
    header .meta-item span { color: var(--dim); font-size: 0.75rem; display: block; }
    header .meta-item strong { color: var(--accent2); font-size: 0.95rem; }

    .container { max-width: 1400px; margin: 0 auto; padding: 2rem 3rem; }

    .toc {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1.5rem;
      margin-bottom: 2rem;
    }
    .toc h2 { color: var(--accent2); margin-bottom: 1rem; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 2px; }
    .toc ul { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .toc ul li a {
      color: var(--accent);
      text-decoration: none;
      font-size: 0.8rem;
      background: var(--surface2);
      border: 1px solid var(--border);
      padding: 0.25rem 0.75rem;
      border-radius: 20px;
      transition: all 0.2s;
    }
    .toc ul li a:hover { background: var(--accent); color: #000; }

    .module {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      margin-bottom: 1.5rem;
      overflow: hidden;
    }
    .module-header {
      background: var(--surface2);
      padding: 1rem 1.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      border-bottom: 1px solid var(--border);
    }
    .module-header h3 {
      color: var(--accent2);
      font-size: 0.95rem;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .module-header .badge {
      font-size: 0.7rem;
      padding: 0.2rem 0.6rem;
      border-radius: 10px;
      background: var(--accent);
      color: #000;
      font-weight: bold;
    }
    .module-header .file-path {
      margin-left: auto;
      color: var(--dim);
      font-size: 0.75rem;
    }
    .module-content {
      padding: 1rem 1.5rem;
    }
    pre {
      background: #0a0a0a;
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 1rem;
      overflow-x: auto;
      font-size: 0.78rem;
      color: #ccc;
      max-height: 400px;
      overflow-y: auto;
      white-space: pre-wrap;
      word-break: break-all;
    }
    .empty { color: var(--dim); font-style: italic; font-size: 0.85rem; }

    footer {
      border-top: 1px solid var(--border);
      text-align: center;
      padding: 1.5rem;
      color: var(--dim);
      font-size: 0.8rem;
    }
    footer span { color: var(--accent); }

    .warning-banner {
      background: linear-gradient(90deg, #2a1a00, #1a0000);
      border: 1px solid var(--yellow);
      border-radius: 8px;
      padding: 1rem 1.5rem;
      margin-bottom: 2rem;
      color: var(--yellow);
      font-size: 0.85rem;
    }
  </style>
</head>
<body>

<header>
  <h1>⚡ DARKWIN</h1>
  <div style="color: var(--dim); font-size:0.8rem; margin-top:0.25rem;">Advanced Automation Toolkit — Scan Report</div>
  <div class="meta">
    <div class="meta-item">
      <span>Target</span>
      <strong>{{ target }}</strong>
    </div>
    <div class="meta-item">
      <span>Scan Date</span>
      <strong>{{ scan_date }}</strong>
    </div>
    <div class="meta-item">
      <span>Modules Run</span>
      <strong>{{ modules|length }}</strong>
    </div>
    <div class="meta-item">
      <span>Output Directory</span>
      <strong>{{ output_dir }}</strong>
    </div>
    <div class="meta-item">
      <span>Generated By</span>
      <strong>{{ generated_by }}</strong>
    </div>
  </div>
</header>

<div class="container">

  <div class="warning-banner">
    ⚠ <strong>AUTHORIZED USE ONLY</strong> — This report was generated by DARKWIN for authorized security testing purposes only.
    Unauthorized use of this data or the tools that produced it is illegal.
  </div>

  <!-- Table of Contents -->
  <div class="toc">
    <h2>📋 Modules</h2>
    <ul>
      {% for key, data in modules.items() %}
      <li><a href="#{{ key }}">{{ key.replace('_', ' ').title() }}</a></li>
      {% endfor %}
    </ul>
  </div>

  <!-- Module Results -->
  {% for key, data in modules.items() %}
  <div class="module" id="{{ key }}">
    <div class="module-header">
      <h3>{{ key.replace('_', ' ').title() }}</h3>
      <span class="badge">{{ data.type | upper }}</span>
      <span class="file-path">{{ data.file }}</span>
    </div>
    <div class="module-content">
      {% if data.type == 'json' %}
        {% if data.content %}
          <pre>{{ data.content | tojson(indent=2) }}</pre>
        {% else %}
          <span class="empty">No results captured.</span>
        {% endif %}
      {% else %}
        {% if data.content and data.content.strip() %}
          <pre>{{ data.content[:5000] }}</pre>
        {% else %}
          <span class="empty">No results captured.</span>
        {% endif %}
      {% endif %}
    </div>
  </div>
  {% else %}
  <p style="color: var(--dim); text-align: center; padding: 3rem;">
    No scan results found. Run a pipeline first.
  </p>
  {% endfor %}

</div>

<footer>
  Generated by <span>DARKWIN v1.0.0</span> &mdash; Developed by **ARYAN AHIRWAR (VIPHACKER.100)** &mdash; {{ scan_date }}
</footer>

</body>
</html>
